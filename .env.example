# --- Database (Supabase Postgres) ---------------------------------------
# Pooled connection used by the running app (Vercel serverless functions).
# Supabase exposes this under "Connection pooling" → Transaction mode.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct (non-pooled) connection used by `prisma migrate deploy`.
# Supabase exposes this under "Connection string" → "URI". Same DB, port 5432.
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# --- Session cookie (used from feature/session-progress-api onwards) -----
# Random 32+ byte secret used to HMAC-sign the anonymous session cookie.
# Generate with: openssl rand -base64 48
SESSION_COOKIE_SECRET="replace-with-a-long-random-secret"

# --- Mock payment webhook (ADR-017) -------------------------------------
# Shared secret the simulated payment provider signs its webhook with, and
# the `/api/v1/payments/webhook` handler verifies (HMAC-SHA256). Entitlement
# is granted ONLY from a signature-verified webhook — the browser checkout
# endpoint cannot mint `paid`. Generate with: openssl rand -base64 48
PAYMENT_WEBHOOK_SECRET="replace-with-a-long-random-secret"

# --- Internal-fetch host allowlist (optional, recommended in prod) -------
# When set, server-side RSC fetches to our own /api/v1 use this exact
# origin instead of trusting the forwarded host/proto headers. Leaving
# it unset preserves the existing forwarded-header behaviour (handy for
# cURL/local). Must be a full origin (scheme + host[:port]), no path.
# APP_ORIGIN="https://project-u415a.vercel.app"
