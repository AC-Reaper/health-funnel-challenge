# --- Database (Supabase Postgres) ---------------------------------------
# Pooled connection used by the running app (Vercel serverless functions).
# Supabase exposes this under "Connection pooling" → Transaction mode.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct (non-pooled) connection used by `prisma migrate deploy`.
# Supabase exposes this under "Connection string" → "URI". Same DB, port 5432.
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# --- Session cookie (used from feature/session-progress-api onwards) -----
# Random 32+ byte secret used to HMAC-sign the anonymous session cookie.
# Generate with: openssl rand -base64 48
SESSION_COOKIE_SECRET="replace-with-a-long-random-secret"
